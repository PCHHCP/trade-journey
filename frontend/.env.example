# ============================================
# Tyche 前端 - 环境变量模板
# ============================================
#
# 用法：
#   cp .env.example .env.development   -> 本地开发，执行 `vite dev` 时加载
#   cp .env.example .env.production    -> 生产构建，执行 `vite build` 时加载
#
# Vite 会根据 mode 自动加载对应文件：
#   vite dev   -> .env.development
#   vite build -> .env.production
#
# 只有以 VITE_ 开头的变量才会暴露给前端代码
# ============================================

# --- Supabase 认证 ---
# Supabase 项目地址
# 获取位置：Supabase Dashboard > Project Settings > API > Project URL
VITE_SUPABASE_URL=

# Supabase 匿名公钥，可安全暴露在前端
# 获取位置：Supabase Dashboard > Project Settings > API > anon public
VITE_SUPABASE_ANON_KEY=

# --- 后端 API ---
# 后端 API 基础地址，末尾不要带斜杠
# 本地示例：http://localhost:8000  |  生产示例：https://api.tyche.com
VITE_API_URL=
