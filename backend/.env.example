# ============================================
# Tyche 后端 - 环境变量模板
# ============================================
#
# 用法：
#   cp .env.example .env              -> 本地开发，默认由 pydantic-settings 加载
#   cp .env.example .env.production   -> 生产环境，配合 APP_ENV=production 使用
#
# ============================================

# --- 数据库 ---
# 异步 PostgreSQL 连接串，必须使用 asyncpg 驱动
# 格式：postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=

# --- Supabase 认证 ---
# Supabase 项目地址，后端会从这里的 auth/v1/.well-known/jwks.json 拉取公钥
# 格式：https://<project-ref>.supabase.co
SUPABASE_URL=

# --- 跨域配置 ---
# 允许访问后端的前端来源列表，多个地址用英文逗号分隔
# 本地示例：http://localhost:5173  |  生产示例：https://tyche.com
CORS_ORIGINS=

# --- 调试模式 ---
# 是否启用调试模式（SQL 输出、更详细日志），生产环境应设为 false
DEBUG=
